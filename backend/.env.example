# Example environment variables for the backend. Copy this file to `.env` and fill in the values.

# Database connection settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fantasy_advisor
DB_NAME=fantasy_advisor
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Secret key for JWT authentication
JWT_SECRET_KEY=your_jwt_secret_key

# API key for any third-party services (e.g., sports data providers)
SLEEPER_API_KEY=your_sports_api_key

